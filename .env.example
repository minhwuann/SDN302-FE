# ====== Ví Vi Vu Web FE ======
# URL gốc của Backend API (bao gồm cả prefix /api/v1)
# Khi chạy BE local mặc định:
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Google OAuth 2.0 Client ID (loại "Web application") dùng cho Google Identity Services.
# Giá trị này PHẢI nằm trong danh sách GOOGLE_CLIENT_IDS của Backend.
VITE_GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
